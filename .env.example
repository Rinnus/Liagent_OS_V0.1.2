# API mode configuration (optional)
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-xxx
# LLM_API_MODEL=gpt-4o
# LIAGENT_MODELS_DIR=/absolute/path/to/liagent-models
# LIAGENT_REASONING_MODEL_PATH=/absolute/path/to/liagent-models/GLM-4.7-Flash-4bit

# TTS_API_BASE_URL=https://api.openai.com/v1
# TTS_API_KEY=sk-xxx
# TTS_API_MODEL=tts-1
# TTS_API_VOICE=alloy

# Finnhub (stock analysis)
# FINNHUB_API_KEY=your_key_here

# Web security
# LIAGENT_WEB_TOKEN=change-me
# LIAGENT_WEB_RATE_LIMIT_PER_MIN=120
# LIAGENT_ALLOW_HIGH_RISK_TOOLS=false
# LIAGENT_TOOL_PROFILE=research
# LIAGENT_ALLOWED_TOOLS=web_search,stock,screenshot
# LIAGENT_CONFIRM_RISK_LEVELS=high
# LIAGENT_CONFIRM_TOOLS=screenshot
# LIAGENT_MAX_TOOL_CALLS_PER_TURN=3
# LIAGENT_TOOL_TIMEOUT_SEC=20
# LIAGENT_TOOL_RETRY_ON_ERROR=1
# LIAGENT_DUP_TOOL_LIMIT=2
# LIAGENT_TOOL_CACHE_ENABLED=true
# LIAGENT_ENABLE_POLICY_REVIEW=true
# LIAGENT_DISABLE_POLICY_REVIEW_IN_VOICE=true
# LIAGENT_ADAPTIVE_TIER=true
# LIAGENT_ADAPTIVE_QUEUE_MS=350
# LIAGENT_ADAPTIVE_TTS_MS=1800
# LIAGENT_ADAPTIVE_TOTAL_MS=3200
# LIAGENT_ADAPTIVE_QUEUE_MS_SEVERE=800
# LIAGENT_ADAPTIVE_TTS_MS_SEVERE=3200
# LIAGENT_ADAPTIVE_TOTAL_MS_SEVERE=6200
# LIAGENT_ALLOW_NETWORK_TOOLS=true
# LIAGENT_ALLOW_FILESYSTEM_TOOLS=true
# LIAGENT_TOOL_OUTPUT_MAX_CHARS=2000
